{
	"name": "reliability",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n \"api,web\" -c \"cyan,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
		"dev:frontend": "vite dev",
		"dev:backend": "tsx watch src/lib/server/server.ts",
		"build": "vite build && npm run build:backend",
		"build:backend": "esbuild src/lib/server/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:better-sqlite3",
		"start": "node dist/server.cjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@fastify/middie": "^9.3.2",
		"@lucia-auth/adapter-sqlite": "^3.0.2",
		"better-sqlite3": "^11.10.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"jspdf": "^4.2.1",
		"jspdf-autotable": "^5.0.8",
		"lucia": "^3.2.2",
		"xlsx": "^0.18.5",
		"zod": "^4.4.3"
	}
}
